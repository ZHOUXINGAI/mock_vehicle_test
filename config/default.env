# Default SITL rover trainer settings.
#
# Copy this file or source it before running scripts if you want stable local
# overrides:
#
#   set -a
#   source config/default.env
#   set +a
#   ./start.sh

PX4_INSTANCE=1
PX4_NAMESPACE=/px4_1
PX4_SYS_AUTOSTART=50000
PX4_SIM_MODEL=gz_rover_differential
PX4_GZ_WORLD=rover
PX4_SIMULATOR=gz

MISSION_MODE=position
TRAVEL_DISTANCE_M=3.0
FENCE_RADIUS_M=10.0
FORWARD_SPEED_MPS=0.7
RETURN_SPEED_MPS=0.5
ARM_ON_START=true

# Keep false by default so this repo does not disturb an easydocking/Claude run.
MOCK_ALLOW_SHARED_SYSTEM=false
